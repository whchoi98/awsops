# AWSops Dashboard Environment Variables
# Copy to .env.local and fill in values

# Steampipe (optional — defaults to 'steampipe')
STEAMPIPE_PASSWORD=steampipe

# AWS Region (optional — defaults to ap-northeast-2)
AWS_REGION=ap-northeast-2

# Node.js
NODE_ENV=production
PORT=3000

# Next.js
NEXT_PUBLIC_BASE_PATH=/awsops
