{
  "project": "awsops-dashboard",
  "description": "AWS/K8s operations dashboard with Steampipe, Next.js, Bedrock AgentCore",
  "defaultModel": "claude-sonnet-4-6",
  "contextFiles": [
    "CLAUDE.md",
    "scripts/ARCHITECTURE.md",
    "docs/TROUBLESHOOTING.md"
  ],
  "permissions": {
    "allow": [],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Bash(git branch -D:*)",
      "Bash(chmod 777:*)",
      "Bash(eval:*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)",
      "Bash(curl*|*bash:*)",
      "Bash(curl*|*sh:*)",
      "Bash(wget*|*bash:*)",
      "Bash(wget*|*sh:*)"
    ]
  },
  "skills": {
    "code-review": ".claude/skills/code-review/SKILL.md",
    "refactor": ".claude/skills/refactor/SKILL.md",
    "release": ".claude/skills/release/SKILL.md",
    "sync-docs": ".claude/skills/sync-docs/SKILL.md",
    "sync-guides": ".claude/skills/sync-guides/SKILL.md"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-context.sh 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/secret-scan.sh \"$TOOL_INPUT_PATH\" 2>/dev/null"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-commit.sh 2>/dev/null || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-doc-sync.sh \"$TOOL_INPUT_PATH\" 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/accumulate-pending-guides.sh \"$TOOL_INPUT_PATH\" 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/check-guide-i18n-sync.sh \"$TOOL_INPUT_PATH\" 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/check-menu-guide-sync.sh \"$TOOL_INPUT_PATH\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-build.sh 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
